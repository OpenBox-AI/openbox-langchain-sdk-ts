{
  "name": "@openbox/langchain-sdk",
  "version": "0.1.0",
  "description": "OpenBox governance and observability SDK for LangChain",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "openbox",
    "langchain",
    "governance",
    "observability",
    "ai-safety",
    "llm",
    "hitl",
    "guardrails",
    "langchain-callback"
  ],
  "author": "OpenBox",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openbox-ai/openbox-langchain-sdk"
  },
  "homepage": "https://github.com/openbox-ai/openbox-langchain-sdk#readme",
  "bugs": {
    "url": "https://github.com/openbox-ai/openbox-langchain-sdk/issues"
  },
  "sideEffects": false
}
