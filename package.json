{
  "name": "openbox-langchain-governance",
  "version": "1.0.1",
  "description": "OpenBox LangChain adapter for TypeScript — governance + observability parity over @openbox-ai/openbox-sdk-ts for LangChain JS/TS agents",
  "license": "MIT",
  "author": "OpenBox Team",
  "homepage": "https://github.com/OpenBox-AI/openbox-langchain-sdk-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenBox-AI/openbox-langchain-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/OpenBox-AI/openbox-langchain-sdk-ts/issues"
  },
  "keywords": [
    "openbox",
    "langchain",
    "governance",
    "observability",
    "agents",
    "middleware",
    "sdk"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24.10.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js",
      "default": "./dist/middleware/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "ci:check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run import:check",
    "clean": "rm -rf coverage dist",
    "example:content-writer": "node examples/content-builder-agent/content-writer.ts",
    "example:smoke": "node examples/content-builder-agent/run-smoke-agent.ts",
    "format": "prettier --write .",
    "import:check": "node scripts/check-root-import-light.mjs",
    "lint": "eslint .",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@openbox-ai/openbox-sdk-ts": "file:../openbox-sdk-ts"
  },
  "peerDependencies": {
    "langchain": "^1.5.2"
  },
  "peerDependenciesMeta": {
    "langchain": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@google/genai": "^2.10.0",
    "@langchain/openai": "^1.5.4",
    "@tavily/core": "^0.7.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitest/coverage-v8": "^3.2.4",
    "chalk": "^4.1.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "js-yaml": "^4.3.0",
    "langchain": "^1.5.2",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vitest": "^3.2.4",
    "zod": "^4.4.3"
  }
}
