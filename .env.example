# OpenBox Core API key — required
OPENBOX_API_KEY=obx_live_replace_me

# OpenBox Core API URL. Defaults to https://core.openbox.ai for production.
# Use http://openbox-core-server:8086 when running against a local docker stack.
OPENBOX_API_URL=https://core.openbox.ai

# Agent identity for signed requests (AIP protocol) — optional.
# Only needed if your OpenBox Core deployment enforces request signing.
# Without these, requests still work via the Bearer API key alone.
# OPENBOX_AGENT_DID = did:key:... issued when you register the agent identity.
# OPENBOX_AGENT_PRIVATE_KEY = base64-encoded 32-byte Ed25519 seed for that DID.
OPENBOX_AGENT_DID=
OPENBOX_AGENT_PRIVATE_KEY=

# OpenRouter — used as the LLM provider in examples
OPENROUTER_API_KEY=
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (optional — for local LLM examples)
OLLAMA_MODEL=tinyllama

# Governance hooks
OPENBOX_HOOKS_ENABLED=true
OPENBOX_HOOKS_HTTP=true
OPENBOX_HOOKS_DB=true
OPENBOX_HOOKS_DEBUG=false
