coverage/

# Build / tooling caches
*.tsbuildinfo
.eslintcache

# npm pack/publish artifacts
*.tgz

# OS / editor noise
.DS_Store
Thumbs.db
*.log

# Local Claude settings
.claude/settings.local.json

# Internal working artifacts — kept local, not published to the public repo
_notes/
plans/
proposals/
